{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "ERROR_TRACKING_PROVIDER": {
      "type": "string",
      "enum": ["sentry"],
      "description": "Error tracking provider"
    },
    "SENTRY_DSN": {
      "type": "string",
      "description": "Sentry DSN (Data Source Name) from your Sentry project settings",
      "sensitive": true
    },
    "SENTRY_ENVIRONMENT": {
      "type": "string",
      "description": "Environment tag (e.g. 'production', 'staging', 'development')",
      "default": "development"
    },
    "SENTRY_TRACES_SAMPLE_RATE": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Fraction of transactions to capture for performance monitoring (0.0–1.0). Use 1.0 for development, 0.1–0.2 for production.",
      "default": 1.0
    }
  },
  "required": ["ERROR_TRACKING_PROVIDER", "SENTRY_DSN"]
}
