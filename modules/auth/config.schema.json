{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "AUTH_PROVIDER": {
      "type": "string",
      "enum": ["better-auth", "clerk", "privy"],
      "description": "Auth provider to use"
    },
    "BETTER_AUTH_URL": {
      "type": "string",
      "description": "Base URL of the Better Auth server (e.g. http://localhost:3000)"
    },
    "BETTER_AUTH_SECRET": {
      "type": "string",
      "description": "Secret key for Better Auth token signing. Generate with: openssl rand -hex 32",
      "sensitive": true
    },
    "CLERK_SECRET_KEY": {
      "type": "string",
      "description": "Clerk secret key (sk_live_... or sk_test_...)",
      "sensitive": true
    },
    "CLERK_PUBLISHABLE_KEY": {
      "type": "string",
      "description": "Clerk publishable key (pk_live_... or pk_test_...)"
    },
    "CLERK_WEBHOOK_SECRET": {
      "type": "string",
      "description": "Webhook signing secret for verifying Clerk webhook payloads",
      "sensitive": true
    }
  },
  "required": ["AUTH_PROVIDER"],
  "if": {
    "properties": { "AUTH_PROVIDER": { "const": "better-auth" } }
  },
  "then": {
    "required": ["BETTER_AUTH_URL", "BETTER_AUTH_SECRET"]
  },
  "else": {
    "if": {
      "properties": { "AUTH_PROVIDER": { "const": "clerk" } }
    },
    "then": {
      "required": ["CLERK_SECRET_KEY", "CLERK_PUBLISHABLE_KEY"]
    }
  }
}
