// Package bootstrap initializes all modules in the correct order and wires them together.
// Module initialization order (from composition-rulebook.md §3):
//   1. observability  — must be first
//   2. error-tracking — must be second
//   3. cache          — before auth and jobs
//   4. auth           — after cache
//   5. remaining modules in any order
package bootstrap

import (
	"context"
	"fmt"
	"net/http"
	"os"

	// Module implementations — copied from registry into modules/ during modkit init
	{{- if .HasModule "observability"}}
	obspkg "{{.GoModule}}/modules/observability"
	{{- end}}
	{{- if .HasModule "error-tracking"}}
	errpkg "{{.GoModule}}/modules/error-tracking"
	{{- end}}
	{{- if .HasModule "cache"}}
	cachepkg "{{.GoModule}}/modules/cache"
	{{- end}}
	{{- if .HasModule "auth"}}
	authpkg "{{.GoModule}}/modules/auth"
	{{- end}}
	{{- if .HasModule "payments"}}
	paymentspkg "{{.GoModule}}/modules/payments"
	{{- end}}
	{{- if .HasModule "email"}}
	emailpkg "{{.GoModule}}/modules/email"
	{{- end}}
	{{- if .HasModule "storage"}}
	storagepkg "{{.GoModule}}/modules/storage"
	{{- end}}
	{{- if .HasModule "jobs"}}
	jobspkg "{{.GoModule}}/modules/jobs"
	{{- end}}

	"{{.GoModule}}/config"
	"{{.GoModule}}/api"
)

// Init initializes all modules and returns a wired HTTP handler and a shutdown function.
// Call shutdown(ctx) during graceful shutdown to flush telemetry and close connections.
func Init(ctx context.Context) (http.Handler, func(context.Context), error) {
	cfg, err := config.Load()
	if err != nil {
		return nil, nil, fmt.Errorf("load config: %w", err)
	}

	var shutdowns []func(context.Context)

	// ── 1. Observability (always first) ─────────────────────────────────────
	{{- if .HasModule "observability"}}
	obsSvc, err := obspkg.New(obspkg.Config{
		ServiceName: cfg.Observability.ServiceName,
		Endpoint:    cfg.Observability.Endpoint,
		LogLevel:    cfg.Observability.LogLevel,
		LogFormat:   cfg.Observability.LogFormat,
	})
	if err != nil {
		return nil, nil, fmt.Errorf("init observability: %w", err)
	}
	shutdowns = append(shutdowns, func(ctx context.Context) { obsSvc.Shutdown(ctx) })
	{{- end}}

	// ── 2. Error tracking (always second) ───────────────────────────────────
	{{- if .HasModule "error-tracking"}}
	errSvc, err := errpkg.New(errpkg.Config{
		SentryDSN:        cfg.ErrorTracking.SentryDSN,
		Environment:      cfg.ErrorTracking.Environment,
		TracesSampleRate: cfg.ErrorTracking.TracesSampleRate,
	})
	if err != nil {
		return nil, nil, fmt.Errorf("init error-tracking: %w", err)
	}
	shutdowns = append(shutdowns, func(ctx context.Context) { errSvc.Flush(ctx) })
	{{- end}}

	// ── 3. Cache (before auth and jobs) ─────────────────────────────────────
	{{- if .HasModule "cache"}}
	cacheSvc, err := cachepkg.New(cachepkg.Config{
		URL:            cfg.Cache.RedisURL,
		MaxConnections: cfg.Cache.MaxConnections,
	})
	if err != nil {
		return nil, nil, fmt.Errorf("init cache: %w", err)
	}
	{{- end}}

	// ── 4. Auth (after cache) ────────────────────────────────────────────────
	{{- if .HasModule "auth"}}
	authSvc, err := authpkg.New(authpkg.Config{
		SecretKey:      cfg.Auth.SecretKey,
		PublishableKey: cfg.Auth.PublishableKey,
		WebhookSecret:  cfg.Auth.WebhookSecret,
	}, cacheSvc)
	if err != nil {
		return nil, nil, fmt.Errorf("init auth: %w", err)
	}
	{{- end}}

	// ── 5. Remaining modules ─────────────────────────────────────────────────
	{{- if .HasModule "payments"}}
	paymentsSvc, err := paymentspkg.New(paymentspkg.Config{
		SecretKey:     cfg.Payments.SecretKey,
		WebhookSecret: cfg.Payments.WebhookSecret,
	})
	if err != nil {
		return nil, nil, fmt.Errorf("init payments: %w", err)
	}
	{{- end}}

	{{- if .HasModule "email"}}
	emailSvc, err := emailpkg.New(emailpkg.Config{
		APIKey:      cfg.Email.APIKey,
		FromDefault: cfg.Email.FromDefault,
	})
	if err != nil {
		return nil, nil, fmt.Errorf("init email: %w", err)
	}
	{{- end}}

	{{- if .HasModule "storage"}}
	storageSvc, err := storagepkg.New(storagepkg.Config{
		Bucket:          cfg.Storage.Bucket,
		Region:          cfg.Storage.Region,
		AccessKeyID:     cfg.Storage.AccessKeyID,
		SecretAccessKey: cfg.Storage.SecretAccessKey,
		Endpoint:        cfg.Storage.Endpoint,
		PublicBaseURL:   cfg.Storage.PublicBaseURL,
	})
	if err != nil {
		return nil, nil, fmt.Errorf("init storage: %w", err)
	}
	{{- end}}

	{{- if .HasModule "jobs"}}
	jobsSvc, err := jobspkg.New(jobspkg.Config{
		RedisURL:     cfg.Cache.RedisURL,
		Concurrency:  cfg.Jobs.Concurrency,
		MaxRetries:   cfg.Jobs.MaxRetries,
		DefaultQueue: cfg.Jobs.DefaultQueue,
	}, cacheSvc)
	if err != nil {
		return nil, nil, fmt.Errorf("init jobs: %w", err)
	}
	go jobsSvc.Start(ctx)
	shutdowns = append(shutdowns, jobsSvc.Stop)
	{{- end}}

	// ── Wire HTTP handler ────────────────────────────────────────────────────
	handler := api.NewRouter(api.Deps{
		AllowedOrigins: cfg.AllowedOrigins,
		// DB: db, // TODO: wire *sql.DB here once database is initialized
		{{- if .HasModule "cache"}}Cache:    cacheSvc,{{- end}}
		{{- if .HasModule "observability"}}Obs:      obsSvc,{{- end}}
		{{- if .HasModule "error-tracking"}}Errors:   errSvc,{{- end}}
		{{- if .HasModule "auth"}}Auth:     authSvc,{{- end}}
		{{- if .HasModule "payments"}}Payments: paymentsSvc,{{- end}}
		{{- if .HasModule "email"}}Email:    emailSvc,{{- end}}
		{{- if .HasModule "storage"}}Storage:  storageSvc,{{- end}}
		{{- if .HasModule "jobs"}}Jobs:     jobsSvc,{{- end}}
	})

	shutdown := func(ctx context.Context) {
		for i := len(shutdowns) - 1; i >= 0; i-- {
			shutdowns[i](ctx)
		}
	}

	return handler, shutdown, nil
}

var _ = os.Getenv // suppress unused import
