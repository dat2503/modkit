// ── Tracing middleware ────────────────────────────────────────────────────────

{{- if .HasModule "observability"}}
func tracingMiddleware(obs contracts.ObservabilityService) func(http.Handler) http.Handler {
	return func(next http.Handler) http.Handler {
		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
			operationName := r.Method + " " + r.URL.Path
			ctx, span := obs.StartSpan(r.Context(), operationName)
			defer span.End()

			span.SetAttribute("http.method", r.Method)
			span.SetAttribute("http.url", r.URL.String())
			span.SetAttribute("http.user_agent", r.UserAgent())

			rw := &responseWriter{ResponseWriter: w, statusCode: http.StatusOK}
			next.ServeHTTP(rw, r.WithContext(ctx))

			span.SetAttribute("http.status_code", rw.statusCode)
		})
	}
}

func loggingMiddleware(obs contracts.ObservabilityService) func(http.Handler) http.Handler {
	return func(next http.Handler) http.Handler {
		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
			start := time.Now()
			rw := &responseWriter{ResponseWriter: w, statusCode: http.StatusOK}
			next.ServeHTTP(rw, r)
			obs.Log(r.Context(), contracts.LogLevelInfo, "request", map[string]any{
				"method":   r.Method,
				"path":     r.URL.Path,
				"status":   rw.statusCode,
				"duration": time.Since(start).Milliseconds(),
			})
		})
	}
}
{{- end}}

// ── Recovery middleware ───────────────────────────────────────────────────────

{{- if .HasModule "error-tracking"}}
func recoveryMiddleware(errSvc contracts.ErrorTrackingService) func(http.Handler) http.Handler {
	return func(next http.Handler) http.Handler {
		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
			defer func() {
				if rec := recover(); rec != nil {
					err, ok := rec.(error)
					if !ok {
						err = fmt.Errorf("panic: %v", rec)
					}
					errSvc.CaptureError(r.Context(), err, contracts.CaptureOptions{
						Tags: map[string]string{"type": "panic"},
					})
					writeError(w, http.StatusInternalServerError, "internal server error")
				}
			}()
			next.ServeHTTP(w, r)
		})
	}
}
{{- end}}

// ── Auth middleware ───────────────────────────────────────────────────────────

{{- if .HasModule "auth"}}
// authRequired wraps a handler to require a valid auth token.
// Extracts the Bearer token from the Authorization header.
func authRequired(auth contracts.AuthService, next http.HandlerFunc) http.HandlerFunc {
	return func(w http.ResponseWriter, r *http.Request) {
		token := strings.TrimPrefix(r.Header.Get("Authorization"), "Bearer ")
		if token == "" {
			writeError(w, http.StatusUnauthorized, "missing authorization header")
			return
		}
		user, err := auth.ValidateToken(r.Context(), token)
		if err != nil {
			writeError(w, http.StatusUnauthorized, "invalid or expired token")
			return
		}
		ctx := context.WithValue(r.Context(), contextKeyUser, user)
		next(w, r.WithContext(ctx))
	}
}

type contextKey string
const contextKeyUser contextKey = "user"

// UserFromContext extracts the authenticated user from the request context.
func UserFromContext(ctx context.Context) (*contracts.AuthUser, bool) {
	user, ok := ctx.Value(contextKeyUser).(*contracts.AuthUser)
	return user, ok
}
{{- end}}

