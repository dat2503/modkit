// Package api wires HTTP routes and middleware.
package api

import (
	"database/sql"
	"net/http"
	{{- if .HasModule "cache"}}
	"time"
	{{- end}}

	contracts "github.com/dat2503/modkit/contracts/go"
)

// Deps holds all module dependencies injected into the router.
type Deps struct {
	AllowedOrigins string
	DB             *sql.DB
	{{- if .HasModule "observability"}}
	Obs contracts.ObservabilityService
	{{- end}}
	{{- if .HasModule "error-tracking"}}
	Errors contracts.ErrorTrackingService
	{{- end}}
	{{- if .HasModule "cache"}}
	Cache contracts.CacheService
	{{- end}}
	{{- if .HasModule "auth"}}
	Auth contracts.AuthService
	{{- end}}
	{{- if .HasModule "payments"}}
	Payments contracts.PaymentsService
	{{- end}}
	{{- if .HasModule "email"}}
	Email contracts.EmailService
	{{- end}}
	{{- if .HasModule "storage"}}
	Storage contracts.StorageService
	{{- end}}
	{{- if .HasModule "jobs"}}
	Jobs contracts.JobsService
	{{- end}}
}

// NewRouter creates the HTTP router with all middleware and routes wired.
func NewRouter(deps Deps) http.Handler {
	mux := http.NewServeMux()

	// ── Middleware stack ─────────────────────────────────────────────────────
	// Applied outermost first: recovery → tracing → logging → auth (on protected routes)

	var handler http.Handler = mux

	// CORS must be outermost to handle preflight OPTIONS before auth
	handler = corsMiddleware(deps.AllowedOrigins)(handler)

	{{- if .HasModule "observability"}}
	handler = tracingMiddleware(deps.Obs)(handler)
	handler = loggingMiddleware(deps.Obs)(handler)
	{{- end}}
	{{- if .HasModule "error-tracking"}}
	handler = recoveryMiddleware(deps.Errors)(handler)
	{{- end}}
	{{- if .HasModule "cache"}}
	// Uncomment to enable rate limiting (100 requests per minute per IP):
	// handler = rateLimitMiddleware(deps.Cache, 100, time.Minute)(handler)
	{{- end}}

	// ── Health ───────────────────────────────────────────────────────────────
	mux.HandleFunc("GET /health", healthHandler)
	mux.HandleFunc("GET /ready", readyHandler(deps))

	// ── API v1 ───────────────────────────────────────────────────────────────
	// TODO: register your route handlers here
	// Example:
	//   h := handlers.New(deps)
	//   mux.HandleFunc("GET /api/v1/invoices", authRequired(deps.Auth, h.ListInvoices))
	//   mux.HandleFunc("POST /api/v1/invoices", authRequired(deps.Auth, h.CreateInvoice))

	{{- if .HasModule "payments"}}
	// Webhook endpoints do NOT use auth middleware
	mux.HandleFunc("POST /api/v1/webhooks/stripe", stripeWebhookHandler(deps.Payments))
	{{- end}}

	{{- if .HasModule "auth"}}
	mux.HandleFunc("POST /api/v1/webhooks/clerk", clerkWebhookHandler(deps.Auth))
	{{- end}}

	return handler
}

// healthHandler returns 200 OK — simple liveness check.
func healthHandler(w http.ResponseWriter, r *http.Request) {
	w.Header().Set("Content-Type", "application/json")
	w.WriteHeader(http.StatusOK)
	w.Write([]byte(`{"status":"ok"}`))
}

// readyHandler verifies database (and cache if available) connectivity.
// Returns 200 if all dependencies are reachable, 503 otherwise.
func readyHandler(deps Deps) http.HandlerFunc {
	return func(w http.ResponseWriter, r *http.Request) {
		w.Header().Set("Content-Type", "application/json")

		if deps.DB != nil {
			if err := deps.DB.PingContext(r.Context()); err != nil {
				w.WriteHeader(http.StatusServiceUnavailable)
				w.Write([]byte(`{"status":"unavailable","error":"database unreachable"}`))
				return
			}
		}

		{{- if .HasModule "cache"}}
		if deps.Cache != nil {
			if err := deps.Cache.Set(r.Context(), "__health_check__", []byte("1"), 10*time.Second); err != nil {
				w.WriteHeader(http.StatusServiceUnavailable)
				w.Write([]byte(`{"status":"unavailable","error":"cache unreachable"}`))
				return
			}
		}
		{{- end}}

		w.WriteHeader(http.StatusOK)
		w.Write([]byte(`{"status":"ready"}`))
	}
}
