# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://{{.Name}}:secret@localhost:5433/{{.Name}}_dev?sslmode=disable
{{- if .HasModule "cache"}}

# ── Cache (Redis) ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
{{- end}}
{{- if .HasModule "auth"}}
{{- if eq (.ImplFor "auth") "better-auth"}}

# ── Auth (Better Auth) ───────────────────────────────────────────────────────
BETTER_AUTH_SECRET=changeme-generate-a-random-secret
BETTER_AUTH_URL=http://localhost:8080
{{- else if eq (.ImplFor "auth") "clerk"}}

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_changeme
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_changeme
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
{{- end}}
{{- end}}
{{- if .HasModule "payments"}}

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_changeme
STRIPE_WEBHOOK_SECRET=whsec_changeme
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_changeme
{{- end}}
{{- if .HasModule "email"}}

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_changeme
EMAIL_FROM=noreply@example.com
{{- end}}
{{- if .HasModule "storage"}}

# ── Storage (S3) ──────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=changeme
AWS_SECRET_ACCESS_KEY=changeme
AWS_REGION=us-east-1
S3_BUCKET=changeme
{{- end}}
{{- if .HasModule "observability"}}

# ── Observability (OpenTelemetry) ─────────────────────────────────────────────
OTEL_SERVICE_NAME={{.Name}}
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
{{- end}}
{{- if .HasModule "error-tracking"}}

# ── Error Tracking (Sentry) ───────────────────────────────────────────────────
SENTRY_DSN=https://changeme@sentry.io/0
SENTRY_ENVIRONMENT=development
{{- end}}
{{- if .HasModule "feature-flags"}}

# ── Feature Flags (Flagsmith) ─────────────────────────────────────────────────
FLAGSMITH_SERVER_API_KEY=changeme
{{- end}}
{{- if .HasModule "admin"}}

# ── Admin (seed script) ───────────────────────────────────────────────────────
# Run `bun run seed` to create the default admin account
ADMIN_DEFAULT_EMAIL=admin@localhost
ADMIN_DEFAULT_PASSWORD=changeme
{{- end}}
{{- if .HasModule "search"}}

# ── Search (Elasticsearch) ────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
{{- end}}

# ── App ───────────────────────────────────────────────────────────────────────
PORT=8080
APP_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:3000
