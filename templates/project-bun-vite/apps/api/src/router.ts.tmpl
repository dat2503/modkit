import { Hono } from 'hono'
import { cors } from 'hono/cors'
import { logger } from 'hono/logger'
import { secureHeaders } from 'hono/secure-headers'
{{- if .HasModule "auth"}}
import type { IAuthService } from '../contracts/ts/auth'
{{- end}}
{{- if .HasModule "payments"}}
import type { IPaymentsService } from '../contracts/ts/payments'
{{- end}}
{{- if .HasModule "email"}}
import type { IEmailService } from '../contracts/ts/email'
{{- end}}
{{- if .HasModule "storage"}}
import type { IStorageService } from '../contracts/ts/storage'
{{- end}}
{{- if .HasModule "jobs"}}
import type { IJobsService } from '../contracts/ts/jobs'
{{- end}}
{{- if .HasModule "realtime"}}
import type { IRealtimeService } from '../contracts/ts/realtime'
{{- end}}
{{- if .HasModule "search"}}
import type { ISearchService } from '../contracts/ts/search'
{{- end}}
{{- if .HasModule "feature-flags"}}
import type { IFeatureFlagsService } from '../contracts/ts/feature-flags'
{{- end}}

export interface Deps {
  allowedOrigins: string
{{- if .HasModule "auth"}}
  auth: IAuthService
{{- end}}
{{- if .HasModule "payments"}}
  payments: IPaymentsService
{{- end}}
{{- if .HasModule "email"}}
  email: IEmailService
{{- end}}
{{- if .HasModule "storage"}}
  storage: IStorageService
{{- end}}
{{- if .HasModule "jobs"}}
  jobs: IJobsService
{{- end}}
{{- if .HasModule "realtime"}}
  realtime: IRealtimeService
{{- end}}
{{- if .HasModule "search"}}
  search: ISearchService
{{- end}}
{{- if .HasModule "feature-flags"}}
  featureFlags: IFeatureFlagsService
{{- end}}
}

export function newRouter(deps: Deps): Hono {
  const app = new Hono()

  const origins = deps.allowedOrigins.split(',').map(o => o.trim())
  app.use('*', cors({
    origin: origins.length === 1 && origins[0] === '*' ? '*' : origins,
    allowMethods: ['GET', 'POST', 'PUT', 'DELETE', 'OPTIONS'],
    allowHeaders: ['Content-Type', 'Authorization'],
    credentials: true,
  }))
  app.use('*', logger())
  app.use('*', secureHeaders())

  // Liveness check — always returns 200
  app.get('/health', (c) => c.json({ status: 'ok' }))

  // Readiness check — verifies dependencies are reachable
  // TODO: wire db and cache checks once initialized
  app.get('/ready', async (c) => {
    // Add dependency checks here, e.g.:
    // await db.execute(sql`SELECT 1`)
    // await cache.set('__health_check__', '1', 10)
    return c.json({ status: 'ready' })
  })
{{- if .HasModule "payments"}}

  // Stripe webhook — raw body required, no auth middleware
  app.post('/webhooks/stripe', async (c) => {
    // TODO: verify Stripe webhook signature, process event
    return c.json({ received: true })
  })
{{- end}}
{{- if .HasModule "auth"}}
{{- if eq (.ImplFor "auth") "better-auth"}}

  // Better Auth handles its own routes (/api/auth/*) — mount if needed
  // app.route('/api/auth', authRoutes)
{{- else if eq (.ImplFor "auth") "clerk"}}

  // Webhook from Clerk for user sync
  app.post('/webhooks/clerk', async (c) => {
    // TODO: verify Clerk webhook signature, sync user data
    return c.json({ received: true })
  })
{{- end}}
{{- end}}

  // TODO: add your routes here
  // Example:
  // app.get('/api/items', authRequired(deps.auth), async (c) => { ... })

  return app
}
